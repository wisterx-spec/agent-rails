{
  "_comment": "复制此文件为 project.config.json 并填入项目实际值。project.config.json 已在 .gitignore 中排除。",

  "project": {
    "name": "my-project",
    "description": "项目简述",
    "root_path": "/path/to/project",
    "tmp_dir": "tmp"
  },

  "agent": {
    "signal_dir": "tmp/agent-signals",
    "delivery_dir": "docs/agent-runs/delivery",
    "management_dir": "docs/agent-runs/management"
  },

  "capabilities": {
    "frontend": true,
    "backend": true,
    "database": true,
    "deploy": true
  },

  "tech_stack": {
    "frontend": "your-frontend-stack-or-none",
    "frontend_path": "path/to/frontend/src",
    "backend": "your-backend-stack-or-none",
    "backend_path": "path/to/backend/src",
    "test_path": "path/to/tests",
    "database": "your-database-or-none",    "_database_options": "可选值示例: none | mysql | sqlite | postgres",
    "orm": "your-data-access-layer-or-none",
    "css_framework": "your-css-framework-or-none",
    "frontend_test_path": "path/to/frontend/tests",  "_frontend_test_path_comment": "前端测试文件根目录，用于 frontend-tdd 工作流的 test_lock.py 基线扫描",
    "frontend_extensions": ["tsx", "ts", "vue"],  "_frontend_extensions_comment": "前端源文件扩展名，用于 scan-frontend-quality 的 grep 扫描，可选值示例: tsx|vue|jsx|svelte"
  },

  "team": {
    "terminology": {
      "frontend_alias": "前端",
      "backend_alias": "后端"
    },
    "knowledge_base_path": "docs/lessons"
  },

  "testing": {
    "local_db_url": "",
    "ci_db_url": "",
    "test_lock_script": ".agents/scripts/test_lock.py",
    "commands": {
      "fast": "replace-with-your-fast-test-command",
      "full": "replace-with-your-full-test-command",
      "frontend_fast": "",
      "backend_fast": "",
      "lint": ""
    },
    "fast_mode_exclude_marks": "slow,performance",
    "full_mode_exclude_marks": ""
  },

  "deploy": {
    "platform": "custom",
    "qa_env_name": "qa",
    "prod_env_name": "production",
    "tag_format": "v{YYYYMMDD-HHMM}-{description}",
    "post_deploy_verify_endpoint": "/api/health",
    "rollback_required": true
  },

  "commit": {
    "affects_field_enabled": false,
    "affects_field_description": "影响的业务模块（逗号分隔）",
    "changed_interfaces_enabled": false
  },

  "llm_context": {
    "core_doc": "docs/llm-context/llms-core.txt",
    "backend_doc": "docs/llm-context/llms-domain-backend.txt",
    "frontend_doc": "docs/llm-context/llms-domain-frontend.txt",
    "max_lines": {
      "core": 40,
      "domain": 30
    }
  },

  "design_system": {
    "reference_file": "frontend/public/design-system.html",
    "semantic_color_prefix": "bg-background-",
    "forbidden_tailwind_colors": ["bg-slate-", "bg-blue-", "bg-gray-", "bg-red-", "bg-green-"]
  },

  "weekly_report": {
    "output_dir": "tmp/weekly_reports",
    "frontend_repo_path": ""
  }
}
